# Copy this file to .env and fill your real values.
# Never share your .env file.

ANGELONE_API_KEY=your_api_key
ANGELONE_CLIENT_ID=your_client_id
ANGELONE_MPIN=your_mpin
ANGELONE_TOTP_SECRET=your_totp_secret

# Safety defaults
PAPER_TRADE=true
EXECUTE_ORDERS=false
ORDER_QUANTITY=0

# Optional Telegram placeholders
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional risk override for both live and backtest
# RISK_MODE=FIXED_POINTS
# ENABLE_MAE_EXIT=true
# MAE_POINTS=400

# --- Execution / order placement safety ---
# Keep PAPER first. LIVE orders require both EXECUTION_ENABLED=true and ALLOW_LIVE_ORDERS=true.
EXECUTION_ENABLED=false
EXECUTION_MODE=PAPER
ALLOW_LIVE_ORDERS=false
EXECUTION_LOTS=1
EXECUTION_QUANTITY=0
EXECUTION_UNDERLYING=BANKNIFTY
EXECUTION_EXPIRY_MODE=NEAREST
TRADE_STARTUP_POSITION=false

# --- Backend API / platform ---
DATABASE_URL=postgresql+psycopg2://trading:trading@postgres:5432/trading
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change_me_to_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Initial admin bootstrap (only used the first time the DB has no users yet)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_to_a_strong_password

# Dashboard build-time API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
