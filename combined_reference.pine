//@version=4
study(title="SVMKR_UT_HMA_ORB_ChopNoADX", shorttitle="SVMKR_UT_HMA_ORB_ChopNoADX", overlay=true)

// =====================================================================
// ORIGINAL UT BOT + HMA + ORB WITH CHOP FILTER - NO ADX VERSION
// Pine v4 compatible
// =====================================================================

// =====================================================================
// UT BOT SETTINGS
// =====================================================================
grpUT = "UT Bot Settings"
a = input(3.0, title="UT Key Value / Sensitivity", group=grpUT)
c = input(14, title="UT ATR Period", group=grpUT)
h = input(false, title="Signals from Heikin Ashi Candles", group=grpUT)

// =====================================================================
// HMA SETTINGS
// =====================================================================
grpHMA = "Hull MA Settings"
n = input(14, title="Hull MA Period", group=grpHMA)

// =====================================================================
// CHOP FILTER SETTINGS - NO ADX
// =====================================================================
grpChop = "Chop Filter - No ADX"
enableChopFilter = input(true, title="Enable Chop Filter", group=grpChop)
chopMode = input(title="Chop Filter Mode", defval="Medium", options=["Off", "Light", "Medium", "Strict"], group=grpChop)

useHmaTrendFilter = input(true, title="Use HMA Trend Direction Filter", group=grpChop)
useHmaSlopeFilter = input(true, title="Use HMA Slope Filter", group=grpChop)
useDistanceFilter = input(true, title="Use ATR Distance From HMA Filter", group=grpChop)
useCooldownFilter = input(true, title="Use Signal Cooldown Filter", group=grpChop)
useRangeFilter    = input(false, title="Use Strict Range Breakout Filter", group=grpChop)

slopeLen = input(3, title="HMA Slope Lookback Bars", minval=1, group=grpChop)
atrNormLen = input(14, title="ATR Normalization Period", minval=1, group=grpChop)
manualSlopeThreshold = input(0.045, title="Manual ATR-Normalized Slope Threshold", minval=0.001, step=0.001, group=grpChop)
useAutoThreshold = input(true, title="Use Auto Threshold by Mode", group=grpChop)

manualDistanceMult = input(0.10, title="Manual Distance From HMA ATR Multiplier", minval=0.01, step=0.01, group=grpChop)
useAutoDistance = input(true, title="Use Auto Distance by Mode", group=grpChop)

cooldownBarsManual = input(3, title="Cooldown Bars After Signal", minval=0, group=grpChop)
rangeLookback = input(9, title="Strict Range Lookback Bars", minval=2, group=grpChop)

showChopBg = input(true, title="Show Chop Background", group=grpChop)
showFilterTable = input(true, title="Show Filter Status Table", group=grpChop)
showBlockedSignals = input(false, title="Show Blocked Raw Signals", group=grpChop)

// =====================================================================
// ORB SETTINGS
// =====================================================================
grpORB = "Open Range Breakout"
inputMax = input(5, title="ORB total time (minutes)", group=grpORB)
sess = input("1010-1015", type=input.session, title="ORB Session Time", group=grpORB)

// =====================================================================
// BACKTEST WINDOW SETTINGS
// =====================================================================
grpBT = "Backtest Window"
useDateFilter = input(false, title="Use Backtest Start / End Filter", group=grpBT)
// Default: 17 Apr 2026 09:15 to 17 Apr 2026 15:30 IST
btStart = input(defval=1776397500000, title="Backtest Start Date & Time (IST)", type=input.time, group=grpBT)
btEnd   = input(defval=1776420000000, title="Backtest End Date & Time (IST)", type=input.time, group=grpBT)
showBTTable  = input(true, title="Show Backtest Summary Table", group=grpBT)
showBTLabels = input(false, title="Show Backtest Entry / Exit Labels", group=grpBT)


// =====================================================================
// HELPER FUNCTIONS
// =====================================================================
f_modeSlopeThreshold(_mode, _manual, _auto) =>
    _auto ? (_mode == "Light" ? 0.030 : _mode == "Medium" ? 0.045 : _mode == "Strict" ? 0.060 : 0.0) : _manual

f_modeDistanceMult(_mode, _manual, _auto) =>
    _auto ? (_mode == "Light" ? 0.06 : _mode == "Medium" ? 0.10 : _mode == "Strict" ? 0.14 : 0.0) : _manual

f_modeCooldown(_mode, _manual) =>
    _mode == "Light" ? max(_manual, 2) : _mode == "Medium" ? max(_manual, 3) : _mode == "Strict" ? max(_manual, 5) : _manual

f_round2(_x) =>
    round(_x * 100.0) / 100.0

f_priceText(_x) =>
    tostring(f_round2(_x))

f_calcTradePoints(_fromPos, _entryPx, _exitPx) =>
    _fromPos == 1 ? (_exitPx - _entryPx) : (_entryPx - _exitPx)

// =====================================================================
// UT BOT ORIGINAL LOGIC
// =====================================================================
xATR  = atr(c)
nLoss = a * xATR

src = h ? security(heikinashi(syminfo.tickerid), timeframe.period, close, lookahead=false) : close

xATRTrailingStop = 0.0
xATRTrailingStop := iff(src > nz(xATRTrailingStop[1], 0) and src[1] > nz(xATRTrailingStop[1], 0), max(nz(xATRTrailingStop[1]), src - nLoss),
   iff(src < nz(xATRTrailingStop[1], 0) and src[1] < nz(xATRTrailingStop[1], 0), min(nz(xATRTrailingStop[1]), src + nLoss),
   iff(src > nz(xATRTrailingStop[1], 0), src - nLoss, src + nLoss)))

pos = 0
pos := iff(src[1] < nz(xATRTrailingStop[1], 0) and src > nz(xATRTrailingStop[1], 0), 1,
   iff(src[1] > nz(xATRTrailingStop[1], 0) and src < nz(xATRTrailingStop[1], 0), -1, nz(pos[1], 0)))

xcolor = pos == -1 ? color.red : pos == 1 ? color.green : color.blue

ema1  = ema(src, 1)
above = crossover(ema1, xATRTrailingStop)
below = crossover(xATRTrailingStop, ema1)

rawBuy  = src > xATRTrailingStop and above
rawSell = src < xATRTrailingStop and below

barbuy  = src > xATRTrailingStop
barsell = src < xATRTrailingStop

// =====================================================================
// HULL MOVING AVERAGE ORIGINAL LOGIC
// =====================================================================
n2ma = 2 * wma(close, round(n / 2))
nma = wma(close, n)
diff = n2ma - nma
sqn = round(sqrt(n))

n2ma1 = 2 * wma(close[1], round(n / 2))
nma1 = wma(close[1], n)
diff1 = n2ma1 - nma1
sqn1 = round(sqrt(n))

hma = wma(diff, sqn)
hmaPrev = wma(diff1, sqn)
hmaUpRaw = hma > hmaPrev

// =====================================================================
// CHOP FILTER LOGIC - NO ADX
// =====================================================================
atrNorm = atr(atrNormLen)

slopeThreshold = f_modeSlopeThreshold(chopMode, manualSlopeThreshold, useAutoThreshold)
distanceMult = f_modeDistanceMult(chopMode, manualDistanceMult, useAutoDistance)
cooldownBars = f_modeCooldown(chopMode, cooldownBarsManual)

hmaSlope = hma - hma[slopeLen]
hmaSlopeNorm = abs(hmaSlope) / max(atrNorm, syminfo.mintick)
hmaSlopeBull = hmaSlope > 0 and hmaSlopeNorm >= slopeThreshold
hmaSlopeBear = hmaSlope < 0 and hmaSlopeNorm >= slopeThreshold

hmaTrendBull = hma > hmaPrev
hmaTrendBear = hma < hmaPrev

distFromHma = abs(close - hma)
distOk = distFromHma >= atrNorm * distanceMult

rangeHighPrev = highest(high, rangeLookback)[1]
rangeLowPrev  = lowest(low, rangeLookback)[1]
rangeBuyOk  = close > rangeHighPrev
rangeSellOk = close < rangeLowPrev

var int lastSignalBar = na
cooldownOk = na(lastSignalBar) or (bar_index - lastSignalBar > cooldownBars)

filtersEnabled = enableChopFilter and chopMode != "Off"

buyHmaTrendOk = not filtersEnabled or not useHmaTrendFilter or hmaTrendBull
sellHmaTrendOk = not filtersEnabled or not useHmaTrendFilter or hmaTrendBear

buySlopeOk = not filtersEnabled or not useHmaSlopeFilter or hmaSlopeBull
sellSlopeOk = not filtersEnabled or not useHmaSlopeFilter or hmaSlopeBear

buyDistanceOk = not filtersEnabled or not useDistanceFilter or distOk
sellDistanceOk = not filtersEnabled or not useDistanceFilter or distOk

buyCooldownOk = not filtersEnabled or not useCooldownFilter or cooldownOk
sellCooldownOk = not filtersEnabled or not useCooldownFilter or cooldownOk

buyRangeOk = not filtersEnabled or not useRangeFilter or rangeBuyOk
sellRangeOk = not filtersEnabled or not useRangeFilter or rangeSellOk

buy  = rawBuy and buyHmaTrendOk and buySlopeOk and buyDistanceOk and buyCooldownOk and buyRangeOk
sell = rawSell and sellHmaTrendOk and sellSlopeOk and sellDistanceOk and sellCooldownOk and sellRangeOk

if buy or sell
    lastSignalBar := bar_index

blockedBuy = rawBuy and not buy
blockedSell = rawSell and not sell

isFlatSlope = filtersEnabled and useHmaSlopeFilter and hmaSlopeNorm < slopeThreshold
isNearHma = filtersEnabled and useDistanceFilter and not distOk
isInCooldown = filtersEnabled and useCooldownFilter and not cooldownOk
isChop = isFlatSlope or isNearHma or isInCooldown

// Stable HMA bias color. Do not flip color during flat/chop.
var int stableBias = 0
if hmaSlopeBull and hmaTrendBull
    stableBias := 1
else if hmaSlopeBear and hmaTrendBear
    stableBias := -1
else
    stableBias := nz(stableBias[1], 0)

hmaColor = stableBias == 1 ? color.green : stableBias == -1 ? color.red : color.blue

// =====================================================================
// PLOTS
// =====================================================================
plot(hma, color=hmaColor, linewidth=2, title="HullMA Stable Bias")
plot(xATRTrailingStop, color=xcolor, title="UT ATR Trailing Stop", linewidth=1)

plotshape(buy, title="Buy", text="Buy", style=shape.labelup, location=location.belowbar, color=color.green, textcolor=color.white, size=size.tiny)
plotshape(sell, title="Sell", text="Sell", style=shape.labeldown, location=location.abovebar, color=color.red, textcolor=color.white, size=size.tiny)

plotshape(showBlockedSignals and blockedBuy, title="Blocked Buy", text="B-Buy", style=shape.triangleup, location=location.belowbar, color=color.gray, textcolor=color.white, size=size.tiny)
plotshape(showBlockedSignals and blockedSell, title="Blocked Sell", text="B-Sell", style=shape.triangledown, location=location.abovebar, color=color.gray, textcolor=color.white, size=size.tiny)

bgcolor(showChopBg and isChop ? color.new(color.gray, 90) : na, title="Chop Background")

// Uncomment below if you want UT bar colors
//barcolor(barbuy ? color.green : barsell ? color.red : na)

alertcondition(buy, "UT Long Filtered", "UT Long Filtered")
alertcondition(sell, "UT Short Filtered", "UT Short Filtered")
alertcondition(blockedBuy, "Blocked UT Long", "Blocked UT Long - Chop Filter")
alertcondition(blockedSell, "Blocked UT Short", "Blocked UT Short - Chop Filter")

// =====================================================================
// BACKTEST ENGINE - FILTERED BUY/SELL SIGNALS
// =====================================================================
inBTWindow = not useDateFilter or (time >= btStart and time <= btEnd)
btWindowEnded = useDateFilter and time > btEnd and time[1] <= btEnd

var int   btPos = 0
var float btEntryPrice = na
var int   btEntryBar = na
var int   btSignals = 0
var int   btTrades = 0
var int   btWins = 0
var int   btLosses = 0
var int   btFlat = 0
var float btGrossProfit = 0.0
var float btGrossLoss = 0.0
var float btNetPoints = 0.0
var float btBestTrade = na
var float btWorstTrade = na
var float btEquityPeak = 0.0
var float btMaxDD = 0.0

// Backtest visual marker flags. Using plotshape avoids Pine v4 label-return type conflicts.
var bool btEntryBuyBar = false
var bool btEntrySellBar = false
var bool btExitLongBar = false
var bool btExitShortBar = false
var bool btEndExitBar = false

btEntryBuyBar := false
btEntrySellBar := false
btExitLongBar := false
btExitShortBar := false
btEndExitBar := false

// Helper note: Pine v4 cannot modify global variables inside a function.
// Trade-stat updates are therefore done inline at each exit block.

if inBTWindow
    if buy or sell
        btSignals := btSignals + 1

    if btPos == 0
        if buy
            btPos := 1
            btEntryPrice := close
            btEntryBar := bar_index
            btEntryBuyBar := true
        else if sell
            btPos := -1
            btEntryPrice := close
            btEntryBar := bar_index
            btEntrySellBar := true

    else if btPos == 1 and sell
        _pts = f_calcTradePoints(1, btEntryPrice, close)

        btTrades := btTrades + 1
        btNetPoints := btNetPoints + _pts
        btBestTrade := na(btBestTrade) ? _pts : max(btBestTrade, _pts)
        btWorstTrade := na(btWorstTrade) ? _pts : min(btWorstTrade, _pts)
        if _pts > 0
            btWins := btWins + 1
            btGrossProfit := btGrossProfit + _pts
        else if _pts < 0
            btLosses := btLosses + 1
            btGrossLoss := btGrossLoss + abs(_pts)
        else
            btFlat := btFlat + 1
        btEquityPeak := max(btEquityPeak, btNetPoints)
        btMaxDD := max(btMaxDD, btEquityPeak - btNetPoints)
        btExitLongBar := true
        btPos := -1
        btEntryPrice := close
        btEntryBar := bar_index

    else if btPos == -1 and buy
        _pts = f_calcTradePoints(-1, btEntryPrice, close)

        btTrades := btTrades + 1
        btNetPoints := btNetPoints + _pts
        btBestTrade := na(btBestTrade) ? _pts : max(btBestTrade, _pts)
        btWorstTrade := na(btWorstTrade) ? _pts : min(btWorstTrade, _pts)
        if _pts > 0
            btWins := btWins + 1
            btGrossProfit := btGrossProfit + _pts
        else if _pts < 0
            btLosses := btLosses + 1
            btGrossLoss := btGrossLoss + abs(_pts)
        else
            btFlat := btFlat + 1
        btEquityPeak := max(btEquityPeak, btNetPoints)
        btMaxDD := max(btMaxDD, btEquityPeak - btNetPoints)
        btExitShortBar := true
        btPos := 1
        btEntryPrice := close
        btEntryBar := bar_index

if btWindowEnded and btPos != 0
    _ptsEnd = f_calcTradePoints(btPos, btEntryPrice, close)
    btTrades := btTrades + 1
    btNetPoints := btNetPoints + _ptsEnd
    btBestTrade := na(btBestTrade) ? _ptsEnd : max(btBestTrade, _ptsEnd)
    btWorstTrade := na(btWorstTrade) ? _ptsEnd : min(btWorstTrade, _ptsEnd)
    if _ptsEnd > 0
        btWins := btWins + 1
        btGrossProfit := btGrossProfit + _ptsEnd
    else if _ptsEnd < 0
        btLosses := btLosses + 1
        btGrossLoss := btGrossLoss + abs(_ptsEnd)
    else
        btFlat := btFlat + 1
    btEquityPeak := max(btEquityPeak, btNetPoints)
    btMaxDD := max(btMaxDD, btEquityPeak - btNetPoints)
    btEndExitBar := true
    btPos := 0
    btEntryPrice := na
    btEntryBar := na

plotshape(showBTLabels and btEntryBuyBar, title="BT BUY", text="BT BUY", style=shape.labelup, location=location.belowbar, color=color.green, textcolor=color.white, size=size.tiny)
plotshape(showBTLabels and btEntrySellBar, title="BT SELL", text="BT SELL", style=shape.labeldown, location=location.abovebar, color=color.red, textcolor=color.white, size=size.tiny)
plotshape(showBTLabels and btExitLongBar, title="BT EXIT LONG", text="EXIT L", style=shape.labeldown, location=location.abovebar, color=color.orange, textcolor=color.black, size=size.tiny)
plotshape(showBTLabels and btExitShortBar, title="BT EXIT SHORT", text="EXIT S", style=shape.labelup, location=location.belowbar, color=color.orange, textcolor=color.black, size=size.tiny)
plotshape(showBTLabels and btEndExitBar, title="BT END EXIT", text="EOD EXIT", style=shape.circle, location=location.absolute, color=color.yellow, textcolor=color.black, size=size.tiny)

btOpenPts = btPos == 0 or na(btEntryPrice) ? 0.0 : f_calcTradePoints(btPos, btEntryPrice, close)
btWinRate = btTrades > 0 ? (btWins / btTrades) * 100.0 : 0.0
btProfitFactor = btGrossLoss > 0 ? btGrossProfit / btGrossLoss : na

var table btTable = table.new(position.bottom_right, 2, 11, border_width=1, border_color=color.gray)
if barstate.islast and showBTTable
    table.cell(btTable, 0, 0, "Backtest Summary", text_color=color.white, bgcolor=color.black)
    table.cell(btTable, 1, 0, useDateFilter ? "Selected Range" : "Full Chart", text_color=color.silver, bgcolor=color.black)

    table.cell(btTable, 0, 1, "Signals", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(btTable, 1, 1, tostring(btSignals), text_color=color.yellow, bgcolor=color.new(color.black, 0))

    table.cell(btTable, 0, 2, "Closed Trades", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(btTable, 1, 2, tostring(btTrades), text_color=color.yellow, bgcolor=color.new(color.black, 0))

    table.cell(btTable, 0, 3, "Wins / Loss / Flat", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(btTable, 1, 3, tostring(btWins) + " / " + tostring(btLosses) + " / " + tostring(btFlat), text_color=color.white, bgcolor=color.new(color.black, 0))

    table.cell(btTable, 0, 4, "Win Rate", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(btTable, 1, 4, tostring(btWinRate, "#.##") + "%", text_color=btWinRate >= 50 ? color.lime : btWinRate >= 40 ? color.yellow : color.red, bgcolor=color.new(color.black, 0))

    table.cell(btTable, 0, 5, "Net Points", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(btTable, 1, 5, tostring(btNetPoints, "#.##"), text_color=btNetPoints >= 0 ? color.lime : color.red, bgcolor=color.new(color.black, 0))

    table.cell(btTable, 0, 6, "Open Points", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(btTable, 1, 6, tostring(btOpenPts, "#.##"), text_color=btOpenPts >= 0 ? color.lime : color.red, bgcolor=color.new(color.black, 0))

    table.cell(btTable, 0, 7, "Profit Factor", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(btTable, 1, 7, na(btProfitFactor) ? "NA" : tostring(btProfitFactor, "#.##"), text_color=na(btProfitFactor) ? color.silver : btProfitFactor >= 1.5 ? color.lime : btProfitFactor >= 1 ? color.yellow : color.red, bgcolor=color.new(color.black, 0))

    table.cell(btTable, 0, 8, "Max DD", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(btTable, 1, 8, tostring(btMaxDD, "#.##"), text_color=color.orange, bgcolor=color.new(color.black, 0))

    table.cell(btTable, 0, 9, "Best / Worst", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(btTable, 1, 9, (na(btBestTrade) ? "NA" : tostring(btBestTrade, "#.##")) + " / " + (na(btWorstTrade) ? "NA" : tostring(btWorstTrade, "#.##")), text_color=color.white, bgcolor=color.new(color.black, 0))

    table.cell(btTable, 0, 10, "Open Position", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(btTable, 1, 10, btPos == 1 ? "LONG" : btPos == -1 ? "SHORT" : "FLAT", text_color=btPos == 1 ? color.lime : btPos == -1 ? color.red : color.silver, bgcolor=color.new(color.black, 0))

// =====================================================================
// OPEN RANGE BREAKOUT ORIGINAL LOGIC
// =====================================================================
t = time(timeframe.period, sess + ":1234567")
hide = timeframe.isintraday and timeframe.multiplier <= inputMax

is_newbar(res) => change(time(res)) != 0
in_session = not na(t)
is_first = in_session and not in_session[1]

orb_high = float(na)
orb_low = float(na)

if is_first
    orb_high := high
    orb_low := low
else
    orb_high := orb_high[1]
    orb_low := orb_low[1]

if high > orb_high and in_session
    orb_high := high
if low < orb_low and in_session
    orb_low := low

plot(hide ? orb_high : na, style=plot.style_line, color=orb_high[1] != orb_high ? na : color.green, title="ORB High", linewidth=1)
plot(hide ? orb_low : na, style=plot.style_line, color=orb_low[1] != orb_low ? na : color.red, title="ORB Low", linewidth=1)

// =====================================================================
// FILTER STATUS TABLE
// =====================================================================
// Pine v4 does not support na() checks on table variables.
// Create table once and update cells on the last bar.
var table statusTable = table.new(position.top_right, 2, 8, border_width=1, border_color=color.gray)
if barstate.islast and showFilterTable

    table.cell(statusTable, 0, 0, "Filter", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 0, "Status", text_color=color.white, bgcolor=color.black)

    table.cell(statusTable, 0, 1, "Mode", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(statusTable, 1, 1, chopMode, text_color=color.yellow, bgcolor=color.new(color.black, 0))

    table.cell(statusTable, 0, 2, "Stable Bias", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(statusTable, 1, 2, stableBias == 1 ? "GREEN" : stableBias == -1 ? "RED" : "NEUTRAL", text_color=stableBias == 1 ? color.lime : stableBias == -1 ? color.red : color.silver, bgcolor=color.new(color.black, 0))

    table.cell(statusTable, 0, 3, "Slope Norm", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(statusTable, 1, 3, tostring(hmaSlopeNorm, "#.###") + " / " + tostring(slopeThreshold, "#.###"), text_color=hmaSlopeNorm >= slopeThreshold ? color.lime : color.red, bgcolor=color.new(color.black, 0))

    table.cell(statusTable, 0, 4, "Distance", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(statusTable, 1, 4, distOk ? "OK" : "NEAR HMA", text_color=distOk ? color.lime : color.red, bgcolor=color.new(color.black, 0))

    table.cell(statusTable, 0, 5, "Cooldown", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(statusTable, 1, 5, cooldownOk ? "OK" : "WAIT", text_color=cooldownOk ? color.lime : color.orange, bgcolor=color.new(color.black, 0))

    table.cell(statusTable, 0, 6, "Chop", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(statusTable, 1, 6, isChop ? "YES" : "NO", text_color=isChop ? color.red : color.lime, bgcolor=color.new(color.black, 0))

    table.cell(statusTable, 0, 7, "Last Raw", text_color=color.silver, bgcolor=color.new(color.navy, 20))
    table.cell(statusTable, 1, 7, rawBuy ? "RAW BUY" : rawSell ? "RAW SELL" : "NONE", text_color=rawBuy ? color.lime : rawSell ? color.red : color.silver, bgcolor=color.new(color.black, 0))

